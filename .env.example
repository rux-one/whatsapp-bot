# Copy to .env and adjust. .env is gitignored — never commit it.
# All values are optional; the bot falls back to sensible defaults if unset.

# Comma-separated group IDs the bot is allowed to act in (e.g. 1203...@g.us).
# Leave empty to respond in ALL groups. When set, messages/joins in other groups are ignored.
WA_ALLOWED_GROUPS=

# LocalAuth session name — lets you run multiple bots / sessions side by side.
WA_CLIENT_ID=whatsapp-bot

# Where the WhatsApp session (login credentials) is stored on disk.
# Point this at a persistent volume in deployment so you don't re-scan the QR.
# Chat history (chat-history.json) is also stored here. Defaults to ./.wwebjs_auth/ when unset.
WA_DATA_PATH=./.wwebjs_auth

# --- LLM (Ollama) ---
# Base URL of the Ollama server and the model used for @mention replies.
# Ollama must be running and the model pulled (`ollama pull <model>`).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Reply sent when the LLM is unreachable (Ollama offline) or errors out.
LLM_FALLBACK_MESSAGE=⚠️ Sorry, I can't reach my brain right now. Please try again in a bit.
